PLATFORM=whatsapp                  # whatsapp or telegram

# WhatsApp settings (only needed if PLATFORM=whatsapp)
MY_PHONE_NUMBER=+1234567890
PUPPETEER_EXECUTABLE_PATH=         # e.g. /usr/bin/chromium-browser on Raspberry Pi, leave blank on Mac/Windows

# Telegram settings (only needed if PLATFORM=telegram)
TELEGRAM_BOT_TOKEN=                # Get from @BotFather on Telegram
TELEGRAM_CHAT_ID=                  # Your Telegram user ID — bot prints it on first message if unset

REMINDER_INTERVAL_MINUTES=60
ESCALATE_AFTER_MINUTES=10
DAILY_GOAL_LITERS=2.0              # Daily water target in liters
DRINK_SIZE_ML=250                  # How many ml each "yes" logs (default: one glass)
SUMMARY_TIME=20:00
QUIET_HOURS_START=23:00
QUIET_HOURS_END=08:00
